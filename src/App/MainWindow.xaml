<Window x:Class="MidiToEverything.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:MidiToEverything.App.ViewModels"
        xmlns:loc="clr-namespace:MidiToEverything.App.Localization"
        mc:Ignorable="d"
        Title="MidiToEverything" Height="600" Width="940" MinWidth="640" MinHeight="420"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" Icon="pack://application:,,,/app.ico"
        FontFamily="Segoe UI" d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Input monitor row: fixed time/source columns, free-width detail (NoWrap → horizontal scroll). -->
        <DataTemplate x:Key="MonitorTemplate" DataType="{x:Type vm:MonitorEntry}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Time}" Width="96" Foreground="{StaticResource TextFaintBrush}"
                           FontFamily="Consolas" FontSize="12" />
                <TextBlock Text="{Binding Source}" Width="180" Foreground="{StaticResource TextDimBrush}"
                           FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding Detail}" Foreground="{Binding Accent}"
                           FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" />
                <TextBlock Text="{Binding ActionLabel}" Foreground="{StaticResource OkBrush}" Margin="12,0,0,0"
                           FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="MidiToEverything" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CaptionButton}" Click="OpenSettings_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="11" Content="&#xE713;" ToolTip="{loc:Tr settings.title}" />
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE921;" />
                <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}" Click="MaxRestore_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE922;" />
                <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
            </StackPanel>
        </Grid>

        <!-- Header bar -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBrush}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Tr main.profileLabel}" Foreground="{StaticResource TextDimBrush}" FontSize="14" />
                        <TextBlock Text="{Binding ActiveProfile}" FontSize="14" FontWeight="SemiBold" />
                        <Border Background="#FF4A3A1E" CornerRadius="4" Padding="6,1" Margin="8,0,0,0"
                                Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{loc:Tr main.pinned}" Foreground="{StaticResource WarnBrush}" FontSize="11" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding ContextWindow}" Foreground="{StaticResource TextFaintBrush}"
                               FontSize="12" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource OkBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmissionEnabled}" Value="False">
                                        <Setter Property="Fill" Value="{StaticResource DangerBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding EmissionLabel}" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="{loc:Tr common.emergencyToggle}" Command="{Binding ToggleEmissionCommand}" Margin="0,0,8,0" />
                    <Button Content="{loc:Tr main.editProfiles}" Click="OpenEditor_Click" Style="{StaticResource AccentButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Update banner (shown when a newer release is available) -->
        <Border Grid.Row="2" Background="{StaticResource AccentBrush}" Padding="14,8"
                Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{loc:Tr update.install}" Command="{Binding InstallUpdateCommand}" Margin="0,0,8,0" />
                    <Button Content="{loc:Tr update.later}" Command="{Binding DismissUpdateCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding UpdateBannerText}" Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="{Binding UpdateStatus}" Foreground="White" Opacity="0.85"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="3" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Devices + detection mode (B-1) -->
            <Border Grid.Column="0" Style="{StaticResource Card}" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr main.devices}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,10" />
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <ToggleButton IsChecked="{Binding IsAutoDetect}" Content="{Binding DetectModeLabel}"
                                      HorizontalAlignment="Stretch"
                                      ToolTip="{loc:Tr main.detect.tip}" />
                        <Button Content="{loc:Tr main.refreshNow}" Command="{Binding RescanDevicesCommand}"
                                Margin="0,6,0,0" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr main.notConnected}" Foreground="{StaticResource TextFaintBrush}" FontSize="12"
                               Visibility="{Binding Devices.Count, Converter={StaticResource ZeroToVisibility}}" />
                    <!-- OBS connection (obs-websocket) for OBS actions -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                        <TextBlock Text="{loc:Tr main.obs.title}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding ObsHost}" ToolTip="{loc:Tr main.obs.host.tip}" />
                            <TextBox Grid.Column="1" Text="{Binding ObsPort}" ToolTip="{loc:Tr main.obs.port.tip}" />
                        </Grid>
                        <TextBox Margin="0,4,0,0" Text="{Binding ObsPassword}"
                                 ToolTip="{loc:Tr main.obs.pass.tip}" />
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}" Margin="0,0,6,0"
                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Input monitor (expanded, vertical + horizontal scroll) -->
            <Border Grid.Column="1" Style="{StaticResource Card}" CornerRadius="8" Padding="12">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="{loc:Tr main.monitor}" FontWeight="SemiBold" Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding TogglePauseCommand}" Margin="0,0,6,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Content" Value="{loc:Tr main.pause}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MonitorPaused}" Value="True">
                                                <Setter Property="Content" Value="{loc:Tr main.resume}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{loc:Tr main.clear}" Command="{Binding ClearMonitorCommand}" />
                        </StackPanel>
                    </Grid>
                    <ListBox ItemsSource="{Binding Monitor}" ItemTemplate="{StaticResource MonitorTemplate}"
                             HorizontalContentAlignment="Left"
                             Background="{StaticResource InputBgBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="False" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
