<Window x:Class="MidiToEverything.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MidiToEverything.App"
        mc:Ignorable="d"
        Title="MidiToEverything" Height="500" Width="820">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="MidiToEverything"
                       FontSize="28" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText"
                       Margin="0,8,0,0" FontSize="14" Opacity="0.7"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
