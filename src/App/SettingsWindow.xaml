<Window x:Class="MidiToEverything.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:loc="clr-namespace:MidiToEverything.App.Localization"
        xmlns:vm="clr-namespace:MidiToEverything.App.ViewModels"
        mc:Ignorable="d"
        Title="{loc:Tr settings.title}" Width="500" Height="520"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/app.ico" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar (app name, like the main window) -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="MidiToEverything" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <Button HorizontalAlignment="Right" Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                    FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
        </Grid>

        <!-- Header bar: same gradient + heading treatment as the main window -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBrush}" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                           Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{loc:Tr settings.title}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Body: content sits on a Card surface like the main window panels -->
        <Border Grid.Row="2" Style="{StaticResource Card}" CornerRadius="8" Margin="12" Padding="6">
        <Grid>
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
            </Grid.LayoutTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <!-- ===== General ===== -->
                <TabItem Header="{loc:Tr settings.tab.general}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,2,10,2">
                        <TextBlock Text="{loc:Tr main.language}" Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                                  Width="220" HorizontalAlignment="Left" Margin="0,3,0,12">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding Display}" /></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <CheckBox Content="{loc:Tr main.runAtStartup}" IsChecked="{Binding RunAtStartup}"
                                  ToolTip="{loc:Tr main.runAtStartup.tip}" Margin="0,5" />
                        <CheckBox Content="{loc:Tr settings.startMinimized}" IsChecked="{Binding StartMinimized}"
                                  ToolTip="{loc:Tr settings.startMinimized.tip}" Margin="0,5" />
                        <CheckBox Content="{loc:Tr settings.closeToTray}" IsChecked="{Binding CloseToTray}"
                                  ToolTip="{loc:Tr settings.closeToTray.tip}" Margin="0,5" />
                        <CheckBox Content="{loc:Tr settings.startEmission}" IsChecked="{Binding StartEmissionEnabled}"
                                  ToolTip="{loc:Tr settings.startEmission.tip}" Margin="0,5" />
                        <CheckBox Content="{loc:Tr settings.trayNotifications}" IsChecked="{Binding TrayNotifications}"
                                  ToolTip="{loc:Tr settings.trayNotifications.tip}" Margin="0,5" />
                        <CheckBox Content="{loc:Tr main.allowLaunch}" IsChecked="{Binding AllowExternalLaunch}"
                                  ToolTip="{loc:Tr main.allowLaunch.tip}" Margin="0,5" />

                        <TextBlock Text="{loc:Tr settings.emergencyHotkey}" Foreground="{StaticResource TextDimBrush}"
                                   FontSize="12" Margin="0,12,0,2" />
                        <TextBox Text="{Binding EmergencyHotkey, UpdateSourceTrigger=PropertyChanged}" Width="220"
                                 HorizontalAlignment="Left" ToolTip="{loc:Tr settings.emergencyHotkey.tip}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding EmergencyHotkeyValid}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== Appearance ===== -->
                <TabItem Header="{loc:Tr settings.tab.appearance}">
                    <StackPanel Margin="2,2,10,2">
                        <Grid Width="220" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.theme}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.accent}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AccentColors}" SelectedItem="{Binding AccentColor}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.uiScale}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding UiScales}" SelectedItem="{Binding UiScale}"
                                      ItemStringFormat="{}{0:P0}" />
                        </Grid>
                    </StackPanel>
                </TabItem>

                <!-- ===== Devices / integration ===== -->
                <TabItem Header="{loc:Tr settings.tab.devices}">
                    <StackPanel Margin="2,2,10,2">
                        <CheckBox Content="{loc:Tr settings.autoDetect}" IsChecked="{Binding IsAutoDetect}"
                                  ToolTip="{loc:Tr main.detect.tip}" Margin="0,5" />

                        <TextBlock Text="{loc:Tr main.obs.title}" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,12,0,2" />
                        <Grid Width="220" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="58" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding ObsHost}" ToolTip="{loc:Tr main.obs.host.tip}" />
                            <TextBox Grid.Column="1" Text="{Binding ObsPort}" ToolTip="{loc:Tr main.obs.port.tip}" />
                        </Grid>
                        <TextBox Width="220" HorizontalAlignment="Left" Margin="0,4,0,0" Text="{Binding ObsPassword}" ToolTip="{loc:Tr main.obs.pass.tip}" />
                    </StackPanel>
                </TabItem>

                <!-- ===== Updates ===== -->
                <TabItem Header="{loc:Tr settings.tab.updates}">
                    <StackPanel Margin="2,2,10,2">
                        <CheckBox Content="{loc:Tr update.autoCheck}" IsChecked="{Binding AutoUpdate}"
                                  ToolTip="{loc:Tr update.autoCheck.tip}" Margin="0,5,0,8" />
                        <Grid Width="220" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.updateChannel}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding UpdateChannels}" SelectedItem="{Binding UpdateChannel}"
                                      ToolTip="{loc:Tr settings.updateChannel.tip}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.updateInterval}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <TextBox Grid.Column="1" Text="{Binding UpdateCheckHours}" ToolTip="{loc:Tr settings.updateInterval.tip}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="{loc:Tr update.checkNow}" Command="{Binding CheckForUpdatesCommand}" />
                            <TextBlock Text="{Binding UpdateStatus}" Foreground="{StaticResource TextFaintBrush}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <!-- ===== Diagnostics / logging ===== -->
                <TabItem Header="{loc:Tr settings.tab.diagnostics}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,2,10,2">
                        <CheckBox Content="{loc:Tr settings.crashAutoRestart}" IsChecked="{Binding CrashAutoRestart}"
                                  ToolTip="{loc:Tr settings.crashAutoRestart.tip}" Margin="0,5" />
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.logLevel}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding LogLevels}" SelectedItem="{Binding LogLevel}"
                                      ToolTip="{loc:Tr settings.logLevel.tip}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.logRetention}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <TextBox Grid.Column="1" Text="{Binding LogRetentionDays}" ToolTip="{loc:Tr settings.logRetention.tip}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.monitorMaxLines}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <TextBox Grid.Column="1" Text="{Binding MonitorMaxLines}" ToolTip="{loc:Tr settings.monitorMaxLines.tip}" />
                        </Grid>
                        <Grid Width="220" HorizontalAlignment="Left" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{loc:Tr settings.monitorThrottle}" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                            <TextBox Grid.Column="1" Text="{Binding MonitorThrottleMs}" ToolTip="{loc:Tr settings.monitorThrottle.tip}" />
                        </Grid>
                        <Button Content="{loc:Tr settings.openLogs}" Command="{Binding OpenLogsFolderCommand}"
                                HorizontalAlignment="Left" Margin="0,8,0,0" />
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== Configuration management ===== -->
                <TabItem Header="{loc:Tr settings.tab.management}">
                    <StackPanel Margin="2,2,10,2">
                        <WrapPanel>
                            <Button Content="{loc:Tr settings.openConfig}" Command="{Binding OpenConfigFolderCommand}" Margin="0,0,6,6" />
                            <Button Content="{loc:Tr settings.export}" Command="{Binding ExportConfigCommand}" Margin="0,0,6,6" />
                            <Button Content="{loc:Tr settings.import}" Command="{Binding ImportConfigCommand}" Margin="0,0,6,6" />
                            <Button Content="{loc:Tr settings.reset}" Command="{Binding ResetSettingsCommand}" Margin="0,0,6,6" />
                        </WrapPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Button Grid.Row="1" HorizontalAlignment="Right" Content="{loc:Tr common.close}"
                    Style="{StaticResource AccentButton}" Click="Close_Click" Margin="0,10,0,0" />
        </Grid>
        </Border>
    </Grid>
</Window>
