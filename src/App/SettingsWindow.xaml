<Window x:Class="MidiToEverything.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:loc="clr-namespace:MidiToEverything.App.Localization"
        xmlns:vm="clr-namespace:MidiToEverything.App.ViewModels"
        mc:Ignorable="d"
        Title="{loc:Tr settings.title}" Width="460" Height="360"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
        Icon="pack://application:,,,/app.ico" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="{loc:Tr settings.title}" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <Button HorizontalAlignment="Right" Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                    FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <!-- Language -->
                <TextBlock Text="{loc:Tr main.language}" Foreground="{StaticResource TextDimBrush}" FontSize="12" />
                <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                          Width="220" HorizontalAlignment="Left" Margin="0,3,0,14">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Display}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Toggles -->
                <CheckBox Content="{loc:Tr main.runAtStartup}" IsChecked="{Binding RunAtStartup}"
                          ToolTip="{loc:Tr main.runAtStartup.tip}" Margin="0,5" />
                <CheckBox Content="{loc:Tr settings.startMinimized}" IsChecked="{Binding StartMinimized}"
                          ToolTip="{loc:Tr settings.startMinimized.tip}" Margin="0,5" />
                <CheckBox Content="{loc:Tr settings.closeToTray}" IsChecked="{Binding CloseToTray}"
                          ToolTip="{loc:Tr settings.closeToTray.tip}" Margin="0,5" />
                <CheckBox Content="{loc:Tr settings.startEmission}" IsChecked="{Binding StartEmissionEnabled}"
                          ToolTip="{loc:Tr settings.startEmission.tip}" Margin="0,5" />
                <CheckBox Content="{loc:Tr main.allowLaunch}" IsChecked="{Binding AllowExternalLaunch}"
                          ToolTip="{loc:Tr main.allowLaunch.tip}" Margin="0,5" />
                <CheckBox Content="{loc:Tr update.autoCheck}" IsChecked="{Binding AutoUpdate}"
                          ToolTip="{loc:Tr update.autoCheck.tip}" Margin="0,5" />

                <!-- Update: manual check -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="{loc:Tr update.checkNow}" Command="{Binding CheckForUpdatesCommand}" />
                    <TextBlock Text="{Binding UpdateStatus}" Foreground="{StaticResource TextFaintBrush}"
                               VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Row="1" HorizontalAlignment="Right" Content="{loc:Tr common.close}"
                    Style="{StaticResource AccentButton}" Click="Close_Click" />
        </Grid>
    </Grid>
</Window>
