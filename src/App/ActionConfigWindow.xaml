<Window x:Class="MidiToEverything.App.ActionConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:loc="clr-namespace:MidiToEverything.App.Localization"
        Title="{loc:Tr dialog.title}" Height="560" Width="600" MinWidth="460" MinHeight="380"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" Icon="pack://application:,,,/app.ico" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="{loc:Tr dialog.title}" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click" HorizontalAlignment="Right"
                    FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
        </Grid>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="18,14,18,14" DataContext="{Binding SelectedBinding}">
            <StackPanel>
                <!-- Header: action kind + one-line description -->
                <TextBlock Text="{Binding ActionKind, Converter={StaticResource ActionKindName}}" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ActionKind, Converter={StaticResource ActionKindHelp}, Mode=OneWay}"
                           Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />

                <!-- Settings -->
                <TextBlock Text="{loc:Tr dialog.settings}" FontWeight="SemiBold" Margin="0,16,0,4" />
                <ContentControl Content="{Binding}" Style="{StaticResource ComplexActionContent}" />

                <!-- Instructions -->
                <TextBlock Text="{loc:Tr dialog.instructions}" FontWeight="SemiBold" Margin="0,16,0,4" />
                <Border Style="{StaticResource Card}" CornerRadius="6" Padding="12">
                    <TextBlock Text="{Binding ActionKind, Converter={StaticResource ActionInstructions}, Mode=OneWay}"
                               Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" FontSize="12"
                               LineHeight="18" />
                </Border>

                <!-- Test (unsaved) -->
                <TextBlock Text="{loc:Tr dialog.test}" FontWeight="SemiBold" Margin="0,16,0,4" />
                <Border Style="{StaticResource Card}" CornerRadius="6" Padding="12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Tr dialog.run}" Style="{StaticResource AccentButton}"
                                    Command="{Binding DataContext.TestActionCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextDimBrush}" FontSize="12"
                                       Text="{Binding DataContext.TestStatus, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                        <TextBlock Text="{loc:Tr dialog.testNote}"
                                   Foreground="{StaticResource TextFaintBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource CaptionBrush}" Padding="14,8">
            <Button Content="{loc:Tr common.close}" HorizontalAlignment="Right" Click="Close_Click" Margin="0" />
        </Border>
    </Grid>
</Window>
