<Window x:Class="MidiToEverything.App.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:edit="clr-namespace:MidiToEverything.App.ViewModels.Editing"
        mc:Ignorable="d"
        Title="プロファイル編集" Height="660" Width="940" MinWidth="600" MinHeight="440"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance edit:ProfileEditorViewModel}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- Inherit the global theme; keep only the editor's local spacing tweaks. -->
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <!-- Per-kind "detail" editors (docs/05 §3.5). DataContext = the draft binding. -->
        <DataTemplate x:Key="KeyDetailTemplate">
            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                      ToolTip="キー（例: ctrl+z）。候補から選択するか自由入力（無効な値は赤字）"
                      ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.Foreground>
                    <MultiBinding Converter="{StaticResource DetailValidBrush}">
                        <Binding Path="Detail" />
                        <Binding Path="ActionKind" />
                    </MultiBinding>
                </ComboBox.Foreground>
            </ComboBox>
        </DataTemplate>

        <DataTemplate x:Key="SwitchProfileDetailTemplate">
            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                      ToolTip="next / prev / toggle またはプロファイルID（無効な値は赤字）"
                      ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.Foreground>
                    <MultiBinding Converter="{StaticResource DetailValidBrush}">
                        <Binding Path="Detail" />
                        <Binding Path="ActionKind" />
                    </MultiBinding>
                </ComboBox.Foreground>
            </ComboBox>
        </DataTemplate>

        <!-- Fixed-set actions (mouse/scroll/cursor): pick from the candidates -->
        <DataTemplate x:Key="ChoiceDetailTemplate">
            <ComboBox ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      SelectedItem="{Binding Detail, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>

        <DataTemplate x:Key="NoneDetailTemplate">
            <TextBlock Text="このバインディングは何もしません（基本プロファイルの同じ割当をブロック）"
                       Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="2,6,0,0" />
        </DataTemplate>

        <DataTemplate x:Key="BrightnessDetailTemplate">
            <TextBlock Text="入力値で画面輝度を設定（フェーダー＝トリガー Absolute 推奨）。内蔵ディスプレイ対応"
                       Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="2,6,0,0" />
        </DataTemplate>

        <!-- Http: URL + method + body -->
        <DataTemplate x:Key="HttpDetailTemplate">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Width="110" Margin="0,0,6,0"
                              ItemsSource="{Binding DataContext.HttpMethods, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding HttpMethod}" ToolTip="HTTPメソッド" />
                    <TextBox Grid.Column="1" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="URL（http(s):// または http://localhost:8123/... など）">
                        <TextBox.Foreground>
                            <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                <Binding Path="Detail" />
                                <Binding Path="ActionKind" />
                            </MultiBinding>
                        </TextBox.Foreground>
                    </TextBox>
                </Grid>
                <TextBox Margin="0,4,0,0" Text="{Binding HttpBody, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinLines="1" MaxLines="4"
                         VerticalScrollBarVisibility="Auto" ToolTip="本文（任意、JSON 等。POST/PUT 時）" />
            </StackPanel>
        </DataTemplate>

        <!-- Obs: operation + argument (scene/input name) -->
        <DataTemplate x:Key="ObsDetailTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" Width="190" Margin="0,0,6,0"
                          ItemsSource="{Binding DataContext.ObsOps, RelativeSource={RelativeSource AncestorType=Window}}"
                          SelectedItem="{Binding ObsOpName}" ToolTip="OBS操作" />
                <TextBox Grid.Column="1" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="sceneswitch=シーン名 / togglemute=入力名（他の操作では不要）" />
            </Grid>
        </DataTemplate>

        <!-- Osc: address + target host:port + args -->
        <DataTemplate x:Key="OscDetailTemplate">
            <StackPanel>
                <TextBox Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="OSCアドレス（例 /1/fader1）">
                    <TextBox.Foreground>
                        <MultiBinding Converter="{StaticResource DetailValidBrush}">
                            <Binding Path="Detail" />
                            <Binding Path="ActionKind" />
                        </MultiBinding>
                    </TextBox.Foreground>
                </TextBox>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,4,0"
                             Text="{Binding OscTarget, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="宛先 host:port（例 127.0.0.1:9000）" />
                    <TextBox Grid.Column="1" Margin="4,0,0,0"
                             Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="引数（空白区切り。整数/小数/文字列を自動判別）" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- TypeText: a free-text snippet (newlines allowed) -->
        <DataTemplate x:Key="TypeTextDetailTemplate">
            <TextBox Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" MinLines="1" MaxLines="4"
                     VerticalScrollBarVisibility="Auto" ToolTip="入力する文字列（改行可）" />
        </DataTemplate>

        <!-- Launch: target + optional arguments + working directory -->
        <DataTemplate x:Key="LaunchDetailTemplate">
            <StackPanel>
                <TextBox Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="対象: 実行ファイル / ファイル / URL / ms-settings: など">
                    <TextBox.Foreground>
                        <MultiBinding Converter="{StaticResource DetailValidBrush}">
                            <Binding Path="Detail" />
                            <Binding Path="ActionKind" />
                        </MultiBinding>
                    </TextBox.Foreground>
                </TextBox>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,4,0"
                             Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="引数（任意）" />
                    <TextBox Grid.Column="1" Margin="4,0,0,0"
                             Text="{Binding WorkingDir, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="作業ディレクトリ（任意）" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Uia: element name (+ picker) + target window + verb + value -->
        <DataTemplate x:Key="UiaDetailTemplate">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="要素名（Name または AutomationId）">
                        <TextBox.Foreground>
                            <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                <Binding Path="Detail" />
                                <Binding Path="ActionKind" />
                            </MultiBinding>
                        </TextBox.Foreground>
                    </TextBox>
                    <Button Grid.Column="1" Content="要素を取得" Margin="6,0,0,0"
                            ToolTip="押した後3秒以内に対象のUI要素へカーソルを合わせると取り込みます"
                            Command="{Binding DataContext.PickUiaElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </Grid>
                <TextBox Margin="0,4,0,0" Text="{Binding UiaWindow, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="対象ウィンドウの正規表現（process\ntitle に一致）。例: ^notepad" />
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Width="150" Margin="0,0,6,0"
                              ItemsSource="{Binding DataContext.UiaVerbs, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding UiaVerb}" ToolTip="動作: invoke / toggle / setvalue" />
                    <TextBox Grid.Column="1" Text="{Binding UiaValue, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="setvalue のとき入力する値" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="プロファイル編集" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE921;" />
                <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}" Click="MaxRestore_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE922;" />
                <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profile list (scrolls when many profiles) -->
            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="10" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="プロファイル" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="追加" Command="{Binding AddProfileCommand}" />
                        <Button Content="削除" Command="{Binding RemoveProfileCommand}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource InputBgBrush}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type edit:EditableProfile}">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Profile details + bindings (whole panel scrolls so nothing is hidden when small) -->
            <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              DataContext="{Binding SelectedProfile}" Padding="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="プロファイル名" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Visibility="{Binding IsBase, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="対象アプリ (起動中から選択、または名前を直接入力 → 候補を追加)" Margin="0,8,0,0" />
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                          ItemsSource="{Binding DataContext.RunningProcesses, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedRunningProcess, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Display"
                                          ToolTip="起動中のウィンドウを持つプロセスから選べます" />
                                <TextBox Grid.Column="1" Margin="0,0,6,0"
                                         Text="{Binding DataContext.ProcessNameInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="手入力 (例: notepad.exe)" />
                                <Button Grid.Column="2" Content="候補を追加" Margin="0,0,6,0"
                                        Command="{Binding DataContext.AddProcessToPatternCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Button Grid.Column="3" Content="更新"
                                        Command="{Binding DataContext.RefreshProcessesCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Grid>
                            <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                       Text="{Binding DataContext.MatchStatus, RelativeSource={RelativeSource AncestorType=Window}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF7FBF7F" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.MatchStatusIsError, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Foreground" Value="#FFE58A8A" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="ウィンドウ判別 (正規表現・自由に編集可)" />
                                    <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"
                                             ToolTip="&quot;プロセス名&#x0a;ウィンドウタイトル&quot; に対してマッチします (複数行)" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="優先度" />
                                    <TextBox Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12" />

                        <!-- Binding list -->
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="バインディング" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="追加" Command="{Binding DataContext.AddBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Button Content="削除" Command="{Binding DataContext.RemoveBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                        <ListBox Height="140" ItemsSource="{Binding Bindings}"
                                 SelectedItem="{Binding DataContext.SelectedBinding, RelativeSource={RelativeSource AncestorType=Window}}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource InputBgBrush}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type edit:EditableBinding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Signal.Type}" Foreground="{StaticResource AccentTextBrush}" />
                                        <TextBlock Text="{Binding Signal.NumberText}" Margin="6,0,0,0" Foreground="{StaticResource AccentTextBrush}" />
                                        <TextBlock Text="  →  " Foreground="{StaticResource TextFaintBrush}" />
                                        <TextBlock Text="{Binding ActionKind}" Foreground="{StaticResource OkBrush}" />
                                        <TextBlock Text="{Binding Detail}" Margin="6,0,0,0" />
                                        <TextBlock Text="{Binding Label}" Margin="10,0,0,0" Foreground="{StaticResource TextFaintBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Binding editor (edits a draft; committed to the list with "保存") -->
                        <Border Background="{StaticResource InputBgBrush}" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                            <Grid>
                                <TextBlock Text="バインディングを「追加」するか、一覧から選択すると、ここで編集できます。"
                                           Foreground="{StaticResource TextFaintBrush}" FontSize="12" TextWrapping="Wrap"
                                           Visibility="{Binding DataContext.HasDraft, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibility}}" />
                                <StackPanel DataContext="{Binding DataContext.DraftBinding, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Visibility="{Binding DataContext.HasDraft, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="シグナル (編集中)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="最後の入力を取込"
                                                    ToolTip="直近に受信した MIDI 信号を、編集中のバインディングの種別/番号/ch/デバイスに取り込みます"
                                                    Command="{Binding DataContext.LearnCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="バインディングを保存" Style="{StaticResource AccentButton}"
                                                    ToolTip="編集中のシグナル内容を確定して保存します（他のバインディングを選ぶか閉じると破棄）"
                                                    Command="{Binding DataContext.CommitBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                <TextBlock Text="{Binding DataContext.LastSignalText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Foreground="#FF7A9AC8" FontSize="11" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding DataContext.LearnStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="11" Margin="0,2,0,6" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF7FBF7F" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.LearnStatusIsError, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFE58A8A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="種別" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="番号" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="ch" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="デバイス (* = 任意)" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.SignalKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Signal.Type}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource SignalKindItem}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                                             ToolTip="番号: 0〜127、または空欄で任意"
                                             Foreground="{Binding Signal.NumberText, Converter={StaticResource NumberValidBrush}}"
                                             Text="{Binding Signal.NumberText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,8,0"
                                             ToolTip="ch: 1〜16、または any"
                                             Foreground="{Binding Signal.Channel, Converter={StaticResource ChannelValidBrush}}"
                                             Text="{Binding Signal.Channel, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="3"
                                             ToolTip="デバイス: 正規表現で判別（* で任意）。例: ^MPK"
                                             Foreground="{Binding Signal.Device, Converter={StaticResource DeviceValidBrush}}"
                                             Text="{Binding Signal.Device, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="トリガー" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="アクション" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="詳細" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.TriggerModes, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Mode}" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.ActionKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding ActionKind}" />
                                    <!-- Per-kind detail editor: template chosen by ActionKind (docs/05 §3.5) -->
                                    <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ContentTemplate" Value="{StaticResource ChoiceDetailTemplate}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Key">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource KeyDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="SwitchProfile">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource SwitchProfileDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="TypeText">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TypeTextDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Launch">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource LaunchDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Uia">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource UiaDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Brightness">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BrightnessDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Http">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource HttpDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Osc">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource OscDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="Obs">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource ObsDetailTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionKind}" Value="None">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource NoneDetailTemplate}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </Grid>

                                <!-- Live help: explains the selected type / trigger / action + field guidance -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="9" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="種別: " Foreground="{StaticResource TextFaintBrush}" /><Run Text="{Binding Signal.Type, Converter={StaticResource SignalKindHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,3,0,0">
                                            <Run Text="トリガー: " Foreground="{StaticResource TextFaintBrush}" /><Run Text="{Binding Mode, Converter={StaticResource TriggerModeHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,3,0,0">
                                            <Run Text="アクション: " Foreground="{StaticResource TextFaintBrush}" /><Run Text="{Binding ActionKind, Converter={StaticResource ActionKindHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextFaintBrush}" Margin="0,6,0,0"
                                                   Text="番号: ノート/CC 番号 (0〜127、PitchBend は空欄)　／　ch: チャンネル (1〜16、any で全チャンネル)　／　デバイス: 対象デバイス名 (* で任意)　／　詳細: 上の「アクション」の説明どおりに入力" />
                                        <TextBlock Text="ラベル (任意): バインディングの覚え書き。動作には影響しません" FontSize="11"
                                                   Foreground="{StaticResource TextFaintBrush}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>

                                    <TextBlock Text="ラベル (任意)" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Bottom bar -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="インポート" Command="{Binding ImportCommand}" />
                    <Button Content="エクスポート" Command="{Binding ExportCommand}" />
                    <TextBlock Text="変更は自動保存されます（シグナル内容のみ「バインディングを保存」で確定）"
                               Foreground="{StaticResource TextFaintBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="閉じる" Command="{Binding CloseCommand}" Margin="0" />
            </Grid>
        </Grid>
    </Grid>
</Window>
