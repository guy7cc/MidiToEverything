<Window x:Class="MidiToEverything.App.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:edit="clr-namespace:MidiToEverything.App.ViewModels.Editing"
        xmlns:loc="clr-namespace:MidiToEverything.App.Localization"
        mc:Ignorable="d"
        Title="{loc:Tr editor.title}" Height="660" Width="940" MinWidth="600" MinHeight="440"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}" Icon="pack://application:,,,/app.ico" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance edit:ProfileEditorViewModel}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                            ResizeBorderThickness="6" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- Inherit the global theme; keep only the editor's local spacing tweaks. -->
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <!-- Per-kind "detail" editors (docs/05 §3.5). DataContext = the draft binding. -->
        <DataTemplate x:Key="KeyDetailTemplate">
            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                      ToolTip="{loc:Tr tip.key}"
                      ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.Foreground>
                    <MultiBinding Converter="{StaticResource DetailValidBrush}">
                        <Binding Path="Detail" />
                        <Binding Path="ActionKind" />
                    </MultiBinding>
                </ComboBox.Foreground>
            </ComboBox>
        </DataTemplate>

        <DataTemplate x:Key="SwitchProfileDetailTemplate">
            <ComboBox IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                      ToolTip="{loc:Tr tip.switchProfile}"
                      ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.Foreground>
                    <MultiBinding Converter="{StaticResource DetailValidBrush}">
                        <Binding Path="Detail" />
                        <Binding Path="ActionKind" />
                    </MultiBinding>
                </ComboBox.Foreground>
            </ComboBox>
        </DataTemplate>

        <!-- Fixed-set actions (mouse/scroll/cursor): pick from the candidates -->
        <DataTemplate x:Key="ChoiceDetailTemplate">
            <ComboBox ItemsSource="{Binding ActionKind, Converter={StaticResource ActionDetailCandidates}}"
                      SelectedItem="{Binding Detail, UpdateSourceTrigger=PropertyChanged}" />
        </DataTemplate>

        <DataTemplate x:Key="NoneDetailTemplate">
            <TextBlock Text="{loc:Tr tip.none}"
                       Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="2,6,0,0" />
        </DataTemplate>

        <DataTemplate x:Key="BrightnessDetailTemplate">
            <TextBlock Text="{loc:Tr tip.brightness}"
                       Foreground="{StaticResource TextFaintBrush}" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="2,6,0,0" />
        </DataTemplate>








        <!-- TypeText: a free-text snippet (newlines allowed) -->
        <DataTemplate x:Key="TypeTextDetailTemplate">
            <TextBox Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" MinLines="1" MaxLines="4"
                     VerticalScrollBarVisibility="Auto" ToolTip="{loc:Tr tip.typeText}" />
        </DataTemplate>


    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource CaptionBrush}">
            <TextBlock Text="{loc:Tr editor.title}" Foreground="{StaticResource TextDimBrush}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE921;" />
                <Button x:Name="MaxRestoreButton" Style="{StaticResource CaptionButton}" Click="MaxRestore_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE922;" />
                <Button Style="{StaticResource CaptionCloseButton}" Click="Close_Click"
                        FontFamily="Segoe MDL2 Assets" FontSize="10" Content="&#xE8BB;" />
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profile list (scrolls when many profiles) -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" CornerRadius="8" Padding="10" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{loc:Tr editor.profiles}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{loc:Tr editor.add}" Command="{Binding AddProfileCommand}" />
                        <Button Content="{loc:Tr editor.remove}" Command="{Binding RemoveProfileCommand}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource InputBgBrush}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type edit:EditableProfile}">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right column: separate boxes (profile+bindings, then signal/trigger/action); whole panel scrolls -->
            <Border Grid.Row="0" Grid.Column="1" Background="Transparent" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              DataContext="{Binding SelectedProfile}" Padding="0,0,8,0">
                    <StackPanel>
                        <!-- ── プロファイルとバインディング編集ボックス ── -->
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                        <TextBlock Text="{loc:Tr editor.profileName}" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Visibility="{Binding IsBase, Converter={StaticResource InverseBoolToVisibility}}">
                            <TextBlock Text="{loc:Tr editor.targetApp}" Margin="0,8,0,0" />
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Margin="0,0,6,0"
                                          ItemsSource="{Binding DataContext.RunningProcesses, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedRunningProcess, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Display"
                                          ToolTip="{loc:Tr editor.targetApp.tip}" />
                                <TextBox Grid.Column="1" Margin="0,0,6,0"
                                         Text="{Binding DataContext.ProcessNameInput, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{loc:Tr editor.targetApp.manualTip}" />
                                <Button Grid.Column="2" Content="{loc:Tr editor.addCandidate}" Margin="0,0,6,0"
                                        Command="{Binding DataContext.AddProcessToPatternCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Button Grid.Column="3" Content="{loc:Tr editor.refresh}"
                                        Command="{Binding DataContext.RefreshProcessesCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Grid>
                            <TextBlock Margin="0,4,0,0" FontSize="11" TextWrapping="Wrap"
                                       Text="{Binding DataContext.MatchStatus, RelativeSource={RelativeSource AncestorType=Window}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF7FBF7F" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.MatchStatusIsError, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Foreground" Value="#FFE58A8A" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{loc:Tr editor.windowMatch}" />
                                    <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"
                                             ToolTip="{loc:Tr tip.windowMatch}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{loc:Tr editor.priority}" />
                                    <TextBox Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12" />

                        <!-- Binding list -->
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="{loc:Tr editor.bindings}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{loc:Tr editor.add}" Command="{Binding DataContext.AddBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Button Content="{loc:Tr editor.remove}" Command="{Binding DataContext.RemoveBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                        </Grid>
                        <ListBox Height="140" ItemsSource="{Binding Bindings}"
                                 SelectedItem="{Binding DataContext.SelectedBinding, RelativeSource={RelativeSource AncestorType=Window}}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource InputBgBrush}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type edit:EditableBinding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Signal.Type}" Foreground="{StaticResource AccentTextBrush}" />
                                        <TextBlock Text="{Binding Signal.NumberText}" Margin="6,0,0,0" Foreground="{StaticResource AccentTextBrush}" />
                                        <TextBlock Text="  →  " Foreground="{StaticResource TextFaintBrush}" />
                                        <TextBlock Text="{Binding ActionKind, Converter={StaticResource ActionKindName}}" Foreground="{StaticResource OkBrush}" />
                                        <TextBlock Text="{Binding Detail}" Margin="6,0,0,0" />
                                        <TextBlock Text="{Binding Label}" Margin="10,0,0,0" Foreground="{StaticResource TextFaintBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </StackPanel>
                        </Border>

                        <!-- Binding editor: signal / trigger / action as sibling boxes; committed with "保存" -->
                        <Grid Margin="0,10,0,0">
                                <TextBlock Text="{loc:Tr editor.bindingPlaceholder}"
                                           Foreground="{StaticResource TextFaintBrush}" FontSize="12" TextWrapping="Wrap"
                                           Visibility="{Binding DataContext.HasDraft, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibility}}" />
                                <StackPanel DataContext="{Binding DataContext.DraftBinding, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Visibility="{Binding DataContext.HasDraft, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                    <!-- ── Signal: which MIDI message this binding listens to ── -->
                                    <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="9">
                                    <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{loc:Tr editor.signalEditing}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="{loc:Tr editor.learnLast}"
                                                    ToolTip="{loc:Tr editor.learnLast.tip}"
                                                    Command="{Binding DataContext.LearnCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="{loc:Tr editor.saveBinding}" Style="{StaticResource AccentButton}"
                                                    ToolTip="{loc:Tr editor.saveBinding.tip}"
                                                    Command="{Binding DataContext.CommitBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </Grid>
                                <TextBlock Text="{Binding DataContext.LastSignalText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Foreground="#FF7A9AC8" FontSize="11" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding DataContext.LearnStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="11" Margin="0,2,0,6" TextWrapping="Wrap">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF7FBF7F" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.LearnStatusIsError, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter Property="Foreground" Value="#FFE58A8A" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Tr editor.kind}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Tr editor.number}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="ch" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{loc:Tr editor.device}" />
                                    <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.SignalKinds, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Signal.Type}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource SignalKindItem}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,8,0"
                                             ToolTip="{loc:Tr field.number.tip}"
                                             Foreground="{Binding Signal.NumberText, Converter={StaticResource NumberValidBrush}}"
                                             Text="{Binding Signal.NumberText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,8,0"
                                             ToolTip="{loc:Tr field.ch.tip}"
                                             Foreground="{Binding Signal.Channel, Converter={StaticResource ChannelValidBrush}}"
                                             Text="{Binding Signal.Channel, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Row="1" Grid.Column="3"
                                             ToolTip="{loc:Tr field.device.tip}"
                                             Foreground="{Binding Signal.Device, Converter={StaticResource DeviceValidBrush}}"
                                             Text="{Binding Signal.Device, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                        <!-- ⓘ What the selected signal kind means -->
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0" Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="ⓘ " Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" /><Run Text="{Binding Signal.Type, Converter={StaticResource SignalKindHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    </Border>

                                    <!-- Signal → Trigger: the arrow labels what the signal sends to the trigger. -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                        <TextBlock Text="↓" FontSize="15" VerticalAlignment="Center" Foreground="{StaticResource TextFaintBrush}" />
                                        <TextBlock Text="{Binding Signal.Type, Converter={StaticResource SignalFlow}, Mode=OneWay}" Margin="8,0,0,0"
                                                   FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource AccentTextBrush}" />
                                    </StackPanel>

                                <!-- ── Trigger: mode + detailed tuning (docs/03 §2) ── -->
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="9" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr editor.trigger}" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{loc:Tr editor.mode}" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" FontSize="11" Foreground="{StaticResource TextFaintBrush}" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding DataContext.TriggerModes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding Mode}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource TriggerModeName}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                        <!-- ⓘ Short concept of the selected mode (how MIDI becomes an action amount). -->
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,6,0,0" Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="ⓘ " Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" /><Run Text="{Binding Mode, Converter={StaticResource TriggerModeHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="↓" HorizontalAlignment="Center" FontSize="14" Margin="0,4,0,2" Foreground="{StaticResource TextFaintBrush}" />
                                        <!-- Only the fields the current mode actually uses are shown; the rest collapse and the row reflows. -->
                                        <WrapPanel Margin="0,6,0,0">
                                            <StackPanel Width="120" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=threshold}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.threshold}" />
                                                <TextBox Text="{Binding Threshold, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Tr field.threshold.tip}" />
                                            </StackPanel>
                                            <StackPanel Width="120" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=rangeMin}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.rangeMin}" />
                                                <TextBox Text="{Binding RangeMin, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Tr field.range.tip}" />
                                            </StackPanel>
                                            <StackPanel Width="120" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=rangeMax}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.rangeMax}" />
                                                <TextBox Text="{Binding RangeMax, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Tr field.range.tip}" />
                                            </StackPanel>
                                            <StackPanel Width="175" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=outOfRange}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.outOfRange}" />
                                                <ComboBox ToolTip="{loc:Tr field.outOfRange.tip}"
                                                          ItemsSource="{Binding DataContext.OutOfRangeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding OutOfRange}">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource OutOfRangeName}}" /></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Width="120" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=deadzone}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.deadzone}" />
                                                <TextBox Text="{Binding Deadzone, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Tr field.deadzone.tip}" />
                                            </StackPanel>
                                            <StackPanel Width="120" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=scale}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.scale}" />
                                                <TextBox Text="{Binding Scale, UpdateSourceTrigger=PropertyChanged}" ToolTip="{loc:Tr field.scale.tip}" />
                                            </StackPanel>
                                            <StackPanel Width="240" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=relativeFormat}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.relativeFormat}" />
                                                <ComboBox ToolTip="{loc:Tr field.relativeFormat.tip}"
                                                          ItemsSource="{Binding DataContext.RelativeFormatOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding RelativeFormat}">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource RelativeFormatName}}" /></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Width="220" Margin="0,0,8,4"
                                                        Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=relativeOutput}">
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr field.relativeOutput}" />
                                                <ComboBox ToolTip="{loc:Tr field.relativeOutput.tip}"
                                                          ItemsSource="{Binding DataContext.RelativeOutputOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding RelativeOutput}">
                                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Converter={StaticResource RelativeOutputName}}" /></DataTemplate></ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <CheckBox Content="{loc:Tr field.invert}" IsChecked="{Binding Invert}" Margin="0,0,18,0"
                                                      ToolTip="{loc:Tr field.invert.tip}"
                                                      Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=invert}" />
                                            <CheckBox Content="{loc:Tr field.edge}" IsChecked="{Binding Edge}"
                                                      ToolTip="{loc:Tr field.edge.tip}"
                                                      Visibility="{Binding Mode, Converter={StaticResource ModeFieldVisible}, ConverterParameter=edge}" />
                                            <CheckBox Content="{loc:Tr field.wrap}" IsChecked="{Binding Wrap}"
                                                      ToolTip="{loc:Tr field.wrap.tip}"
                                                      Visibility="{Binding WrapApplies, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                        <!-- ⓘ Detailed, settings-aware formula: how this turns into the action amount -->
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0"
                                                   Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="ⓘ " Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" /><Run Text="{Binding FireHint, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Trigger → Action: the arrow labels what is sent (a fire event vs an action amount). -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock Text="↓" FontSize="15" VerticalAlignment="Center" Foreground="{StaticResource TextFaintBrush}" />
                                    <TextBlock Text="{Binding FlowLabel, Mode=OneWay}" Margin="8,0,0,0"
                                               FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource AccentTextBrush}" />
                                </StackPanel>

                                <!-- ── Action: kind + detail + relative-direction gate ── -->
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="9" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Tr editor.action}" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr editor.actionKind}" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" Foreground="{StaticResource TextFaintBrush}" Text="{loc:Tr editor.detail}" />
                                            <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                                      ItemsSource="{Binding AvailableActionKinds}"
                                                      SelectedItem="{Binding ActionKind}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource ActionKindName}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <!-- Per-kind detail editor: template chosen by ActionKind (docs/05 §3.5) -->
                                            <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource ChoiceDetailTemplate}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Key">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource KeyDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="SwitchProfile">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource SwitchProfileDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="TypeText">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource TypeTextDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Launch">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Uia">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Brightness">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource BrightnessDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Http">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Osc">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Obs">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="MidiOut">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Macro">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Toggle">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="Plugin">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource ComplexActionDetailTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ActionKind}" Value="None">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource NoneDetailTemplate}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </Grid>
                                        <!-- ⓘ What the action does + how to fill the detail -->
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,8,0,0" Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="ⓘ " Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" /><Run Text="{Binding ActionKind, Converter={StaticResource ActionKindHelp}, Mode=OneWay}" />
                                        </TextBlock>
                                        <!-- ⓘ How this action uses the action amount it receives -->
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0" Foreground="{StaticResource TextDimBrush}">
                                            <Run Text="ⓘ " Foreground="{StaticResource AccentTextBrush}" FontWeight="SemiBold" /><Run Text="{Binding ActionKind, Converter={StaticResource ActionAmountUsage}, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                    <TextBlock Text="{loc:Tr editor.label}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Bottom bar -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button Content="{loc:Tr editor.import}" Command="{Binding ImportCommand}" />
                    <Button Content="{loc:Tr editor.export}" Command="{Binding ExportCommand}" />
                    <TextBlock Text="{loc:Tr editor.autosaveHint}"
                               Foreground="{StaticResource TextFaintBrush}" FontSize="11"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
                <Button HorizontalAlignment="Right" Content="{loc:Tr common.close}" Command="{Binding CloseCommand}" Margin="0" />
            </Grid>
        </Grid>
    </Grid>
</Window>
