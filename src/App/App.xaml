<Application x:Class="MidiToEverything.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MidiToEverything.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <local:ZeroToVisibilityConverter x:Key="ZeroToVisibility" />
            <local:PauseLabelConverter x:Key="PauseLabel" />
            <local:SignalKindHelpConverter x:Key="SignalKindHelp" />
            <local:SignalKindItemConverter x:Key="SignalKindItem" />
            <local:TriggerModeHelpConverter x:Key="TriggerModeHelp" />
            <local:ActionKindHelpConverter x:Key="ActionKindHelp" />
            <local:ActionDetailCandidatesConverter x:Key="ActionDetailCandidates" />
            <local:NumberValidBrushConverter x:Key="NumberValidBrush" />
            <local:ChannelValidBrushConverter x:Key="ChannelValidBrush" />
            <local:DeviceValidBrushConverter x:Key="DeviceValidBrush" />
            <local:DetailValidBrushConverter x:Key="DetailValidBrush" />
            <local:ActionInstructionsConverter x:Key="ActionInstructions" />

            <!-- ====== Complex-action editors, shared by the profile editor and the action-config dialog.
                 DataContext = the draft binding; DataContext.* via the hosting Window = the editor VM. ====== -->
            <Style x:Key="DetailTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="Margin" Value="0,2" />
            </Style>
            <Style x:Key="DetailComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Margin" Value="0,2" />
            </Style>

            <!-- Inline placeholder for complex actions: opens the config dialog. -->
            <DataTemplate x:Key="ComplexActionDetailTemplate">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,0">
                    <Button Content="⚙ 詳細設定…"
                            Command="{Binding DataContext.OpenActionConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextFaintBrush}" MaxWidth="420"
                               VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="LaunchDetailTemplate">
                <StackPanel>
                    <TextBox Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="対象: 実行ファイル / ファイル / URL / ms-settings: など">
                        <TextBox.Foreground>
                            <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                <Binding Path="Detail" /><Binding Path="ActionKind" />
                            </MultiBinding>
                        </TextBox.Foreground>
                    </TextBox>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DetailTextBox}" Margin="0,0,4,0"
                                 Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" ToolTip="引数（任意）" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Margin="4,0,0,0"
                                 Text="{Binding WorkingDir, UpdateSourceTrigger=PropertyChanged}" ToolTip="作業ディレクトリ（任意）" />
                    </Grid>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="UiaDetailTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBox Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="要素名（Name または AutomationId）">
                            <TextBox.Foreground>
                                <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                    <Binding Path="Detail" /><Binding Path="ActionKind" />
                                </MultiBinding>
                            </TextBox.Foreground>
                        </TextBox>
                        <Button Grid.Column="1" Content="要素を取得" Margin="6,0,0,0"
                                ToolTip="押した後3秒以内に対象のUI要素へカーソルを合わせると取り込みます"
                                Command="{Binding DataContext.PickUiaElementCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </Grid>
                    <TextBox Style="{StaticResource DetailTextBox}" Margin="0,4,0,0" Text="{Binding UiaWindow, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="対象ウィンドウの正規表現（process\ntitle に一致）。例: ^notepad" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Style="{StaticResource DetailComboBox}" Width="150" Margin="0,0,6,0"
                                  ItemsSource="{Binding DataContext.UiaVerbs, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding UiaVerb}" ToolTip="動作: invoke / toggle / setvalue" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Text="{Binding UiaValue, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="setvalue のとき入力する値" />
                    </Grid>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="HttpDetailTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" Style="{StaticResource DetailComboBox}" Width="110" Margin="0,0,6,0"
                                  ItemsSource="{Binding DataContext.HttpMethods, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding HttpMethod}" ToolTip="HTTPメソッド" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="URL（http(s):// または http://localhost:8123/... など）">
                            <TextBox.Foreground>
                                <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                    <Binding Path="Detail" /><Binding Path="ActionKind" />
                                </MultiBinding>
                            </TextBox.Foreground>
                        </TextBox>
                    </Grid>
                    <TextBox Style="{StaticResource DetailTextBox}" Margin="0,4,0,0" Text="{Binding HttpBody, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinLines="2" MaxLines="6"
                             VerticalScrollBarVisibility="Auto" ToolTip="本文（任意、JSON 等。POST/PUT 時）" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="OscDetailTemplate">
                <StackPanel>
                    <TextBox Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="OSCアドレス（例 /1/fader1）">
                        <TextBox.Foreground>
                            <MultiBinding Converter="{StaticResource DetailValidBrush}">
                                <Binding Path="Detail" /><Binding Path="ActionKind" />
                            </MultiBinding>
                        </TextBox.Foreground>
                    </TextBox>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DetailTextBox}" Margin="0,0,4,0"
                                 Text="{Binding OscTarget, UpdateSourceTrigger=PropertyChanged}" ToolTip="宛先 host:port（例 127.0.0.1:9000）" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Margin="4,0,0,0"
                                 Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" ToolTip="引数（空白区切り。整数/小数/文字列を自動判別）" />
                    </Grid>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="ObsDetailTemplate">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Style="{StaticResource DetailComboBox}" Width="190" Margin="0,0,6,0"
                              ItemsSource="{Binding DataContext.ObsOps, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding ObsOpName}" ToolTip="OBS操作" />
                    <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="sceneswitch=シーン名 / togglemute=入力名（他の操作では不要）" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="MidiOutDetailTemplate">
                <StackPanel>
                    <TextBox Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="出力デバイス名の正規表現（例 ^loopMIDI）"
                             Foreground="{Binding Detail, Converter={StaticResource DeviceValidBrush}}" />
                    <TextBox Style="{StaticResource DetailTextBox}" Margin="0,4,0,0" Text="{Binding MidiOutSpec, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="メッセージ: 種別 ch 番号 値（cc 1 7 64 / note 1 60 100 / cc 1 7 value で入力値連動 / pc 1 5）" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="MacroDetailTemplate">
                <StackPanel>
                    <TextBox Style="{StaticResource DetailTextBox}" Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="NoWrap" MinLines="3" MaxLines="8"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas"
                             ToolTip="1行に1つのキー（例: ctrl+c / ctrl+v / enter）" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="ステップ間ディレイ(ms):" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,0,6,0" />
                        <TextBox Style="{StaticResource DetailTextBox}" Width="80" Text="{Binding MacroDelay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="ToggleDetailTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DetailTextBox}" Margin="0,0,4,0"
                                 Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}" ToolTip="キーA（奇数回。例 ctrl+r）" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Margin="4,0,0,0"
                                 Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" ToolTip="キーB（偶数回。空ならAと同じ）" />
                    </Grid>
                    <TextBox Style="{StaticResource DetailTextBox}" Margin="0,4,0,0" Text="{Binding ToggleLed, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="LEDフィードバック（任意）: 出力デバイス名 ノート番号 [ch]（例 loopMIDI 36 1）" />
                </StackPanel>
            </DataTemplate>

            <DataTemplate x:Key="PluginDetailTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DetailTextBox}" Margin="0,0,4,0"
                                 Text="{Binding Detail, UpdateSourceTrigger=PropertyChanged}" ToolTip="プラグインID（plugins フォルダの拡張が公開するID）" />
                        <TextBox Grid.Column="1" Style="{StaticResource DetailTextBox}" Margin="4,0,0,0"
                                 Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" ToolTip="コマンド名（プラグインが解釈）" />
                    </Grid>
                    <TextBox Style="{StaticResource DetailTextBox}" Margin="0,4,0,0" Text="{Binding PluginArg, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="引数（任意）" />
                </StackPanel>
            </DataTemplate>

            <!-- Selects the complex-action field template by ActionKind (used in the config dialog). -->
            <Style x:Key="ComplexActionContent" TargetType="ContentControl">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Launch">
                        <Setter Property="ContentTemplate" Value="{StaticResource LaunchDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Uia">
                        <Setter Property="ContentTemplate" Value="{StaticResource UiaDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Http">
                        <Setter Property="ContentTemplate" Value="{StaticResource HttpDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Osc">
                        <Setter Property="ContentTemplate" Value="{StaticResource OscDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Obs">
                        <Setter Property="ContentTemplate" Value="{StaticResource ObsDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="MidiOut">
                        <Setter Property="ContentTemplate" Value="{StaticResource MidiOutDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Macro">
                        <Setter Property="ContentTemplate" Value="{StaticResource MacroDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Toggle">
                        <Setter Property="ContentTemplate" Value="{StaticResource ToggleDetailTemplate}" /></DataTrigger>
                    <DataTrigger Binding="{Binding ActionKind}" Value="Plugin">
                        <Setter Property="ContentTemplate" Value="{StaticResource PluginDetailTemplate}" /></DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
